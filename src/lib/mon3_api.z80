intelHexLoad_      .equ 24
sendToSerial_      .equ 25
receiveFromSerial_ .equ 26
sendAssembly_      .equ 27
sendHex_           .equ 28
genDataDump_       .equ 29
checkStartEnd_     .equ 30
menuDriver_        .equ 31
paramDriver_       .equ 32
timeDelay_         .equ 33
playNote_          .equ 34
playTune_          .equ 35
