matrixScanASCII_   .equ 53
parseMatrixScan_   .equ 54
LCDConfirm_        .equ 55
getGLCDTerm_       .equ 56
setGLCDTerm_       .equ 57

; GLCD API (RST 18H, call number in A)
initLCD_           .equ 0
clearGBUF_         .equ 1
clearGrLCD_        .equ 2
clearTxtLCD_       .equ 3
setGrMode_         .equ 4
setTxtMode_        .equ 5
drawBox_           .equ 6
drawLine_          .equ 7
drawCircle_        .equ 8
drawPixel_         .equ 9
fillBox_           .equ 10
fillCircle_        .equ 11
plotToLCD_         .equ 12
printString_       .equ 13
printChars_        .equ 14
delayUS_           .equ 15
delayMS_           .equ 16
setBufClear_       .equ 17
