flipPixel_         .equ 20
drawGraphic_       .equ 21
invGraphic_        .equ 22
initTerminal_      .equ 23
sendCharToLCD_     .equ 24
sendStringToLCD_   .equ 25
sendRegToLCD_      .equ 26
sendHLToLCD_       .equ 27
setCursor_         .equ 28
getCursor_         .equ 29
displayCursor_     .equ 30

; RTC API (B register value for RTCAPI_)
checkDS1302_       .equ 0
resetDS1302_       .equ 1
getTime_           .equ 2
setTime_           .equ 3
getDate_           .equ 4
setDate_           .equ 5
getDay_            .equ 6
setDay_            .equ 7
get1224Mode_       .equ 8
set12HrMode_       .equ 9
set24HrMode_       .equ 10
readRTCByte_       .equ 11
writeRTCByte_      .equ 12
burstRTCRead_      .equ 13
bcdToBin_          .equ 14
binToBcd_          .equ 15
formatTime_        .equ 16
formatDate_        .equ 17
RTCSetup_          .equ 18
